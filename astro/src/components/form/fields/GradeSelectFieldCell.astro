---
import SelectFieldCell from "./SelectFieldCell.astro";
interface Props {
  name?: string,
  required?: boolean,
  help?: string,
  label: string,
  labelDisplay?: string,
  options: string[],
  grow?: boolean,
  span?: number,
  align?: string,
}
const {
  required = false,
  help = '',
  name = '',
  labelDisplay = 'inline',
  grow = false,
  options = [
    '',
    'Pre-K',
    'Kindergarten',
    '1st Grade',
    '2nd Grade',
    '3rd Grade',
    '4th Grade',
    '5th Grade',
    '6th Grade',
    '7th Grade',
    '8th Grade',
    '9th Grade',
    '10th Grade',
    '11th Grade',
    '12th Grade',
  ],
  span = 12,
  align = 'left',
  label = 'NOLABEL???',
} = Astro.props
---
<SelectFieldCell
    name={name}
    label={label}
    options={options}
    grow={grow}
    span={span}
    align={align} />
