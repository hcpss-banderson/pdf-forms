---
interface Props {
    title?: string,
    subtitle?: string,
}
const { title, subtitle = '' } = Astro.props;
---
<div class="page-header">
    <img alt="HCPSS logo" class="logo" src="./logo.svg">
    <div class="page-title">
        <h1><a href="https://www.hcpss.org">HCPSS</a><span class="seperator"> / </span>{title}</h1>
        {subtitle && <div class="subtitle">{subtitle}</div>}
    </div>
</div>
<style>
    .page-header {
        display: flex;
        align-items: center;
        font-size: 2.5rem;
        border-bottom: 1px solid #ccc;
        padding-bottom: 1rem;
        margin-bottom: 2rem;
        line-height: 90%;
        font-family: 'Open Sans',sans-serif;
    }
    .page-header h1 {
        font-size: 2.5rem;
        margin: 0;
        font-weight: 400;
    }
    .page-header img {
        width: 75px;
        margin-right: 10px;
    }
    .page-header h1 a {
        color: #000;
        font-weight: 800;
        text-decoration: none;
    }
    .subtitle {
        font-size: 70%;
    }
</style>
